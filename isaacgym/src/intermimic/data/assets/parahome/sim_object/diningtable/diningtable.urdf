<?xml version="1.0"?>
<robot name="diningtable">
  <link name="diningtable">
    <contact>
      <lateral_friction value="0.9"/>
      <rolling_friction value="0.5"/>
      <stiffness value="30000"/>
      <damping value="1000"/>
    </contact>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="diningtable/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="diningtable/base_collision.obj"/>
      </geometry>
    </collision>
    <!-- <inertial>
      <mass value="20.000"/>
      <inertia ixx="0.160" ixy="0" ixz="0" iyy="0.160" iyz="0" izz="0.160"/>
    </inertial> -->
  </link>
</robot>
