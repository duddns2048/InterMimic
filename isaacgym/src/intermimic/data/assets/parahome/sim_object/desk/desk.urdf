<?xml version="1.0"?>
<robot name="desk">
  <link name="desk">
    <contact>
      <lateral_friction value="0.9"/>
      <rolling_friction value="0.5"/>
      <stiffness value="30000"/>
      <damping value="1000"/>
    </contact>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="desk/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="desk/base_collision.obj"/>
      </geometry>
    </collision>
    <!-- <inertial>
      <mass value="25.000"/>
      <inertia ixx="0.200" ixy="0" ixz="0" iyy="0.200" iyz="0" izz="0.200"/>
    </inertial> -->
  </link>
</robot>
