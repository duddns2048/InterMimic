<?xml version="1.0"?>
<robot name="pan">
  <link name="pan">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="pan/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="pan/base_collision.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.500"/>
      <inertia ixx="0.060" ixy="0" ixz="0" iyy="0.060" iyz="0" izz="0.060"/>
    </inertial>
  </link>
</robot>
