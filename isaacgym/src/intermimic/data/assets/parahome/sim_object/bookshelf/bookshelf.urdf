<?xml version="1.0"?>
<robot name="bookshelf">
  <link name="bookshelf">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="bookshelf/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="bookshelf/base_collision.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="30.000"/>
      <inertia ixx="0.100" ixy="0" ixz="0" iyy="0.100" iyz="0" izz="0.100"/>
    </inertial>
  </link>
</robot>
