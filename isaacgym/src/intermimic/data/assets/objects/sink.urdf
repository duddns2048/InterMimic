<?xml version="1.0"?>
<robot name="sink">
  <link name="sink">
    <contact>
      <lateral_friction value="0.9"/>
      <rolling_friction value="0.5"/>
      <stiffness value="30000"/>
      <damping value="1000"/>
    </contact>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="objects/sink/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="objects/sink/base_collision.obj"/>
      </geometry>
    </collision>
    <!-- <inertial>
      <mass value="50.000"/>
      <inertia ixx="0.140" ixy="0" ixz="0" iyy="0.140" iyz="0" izz="0.140"/>
    </inertial> -->
  </link>
</robot>
