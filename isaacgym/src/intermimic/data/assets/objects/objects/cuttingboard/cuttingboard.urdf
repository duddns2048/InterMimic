<?xml version="1.0"?>
<robot name="cuttingboard">
  <link name="cuttingboard">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="cuttingboard/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="cuttingboard/base_collision.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.500"/>
      <inertia ixx="0.040" ixy="0" ixz="0" iyy="0.040" iyz="0" izz="0.040"/>
    </inertial>
  </link>
</robot>
