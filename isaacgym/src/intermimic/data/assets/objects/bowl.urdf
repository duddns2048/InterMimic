<?xml version="1.0"?>
<robot name="bowl">
  <link name="bowl">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="objects/bowl/base_visual.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="objects/bowl/base_collision.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.000"/>
      <inertia ixx="0.050" ixy="0" ixz="0" iyy="0.050" iyz="0" izz="0.050"/>
    </inertial>
  </link>
</robot>
